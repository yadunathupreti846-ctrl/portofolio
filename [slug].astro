---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '@utils/formatDate';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

interface Props {
  project: any;
}

const { project } = Astro.props;
const { Content } = await project.render();

const categoryColors = {
  web: 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
  mobile: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
  design: 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200',
};
---

<BaseLayout title={project.data.title} description={project.data.title}>
  <div class="container-custom py-16">
    <article class="max-w-4xl mx-auto">
      <div class="mb-8">
        <div class="flex flex-wrap gap-3 items-center mb-4">
          <span class={`text-sm font-semibold px-3 py-1 rounded-full ${categoryColors[project.data.category]}`}>
            {project.data.category.charAt(0).toUpperCase() + project.data.category.slice(1)}
          </span>
          <span class="text-sm text-gray-500 dark:text-gray-400">
            {formatDate(project.data.date)}
          </span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{project.data.title}</h1>
      </div>
      
      <div class="rounded-xl overflow-hidden mb-8 shadow-xl">
        <img 
          src={project.data.featuredImage} 
          alt={project.data.title}
          class="w-full h-auto"
        />
      </div>
      
      <div class="prose prose-lg dark:prose-invert max-w-none mb-12">
        <Content />
      </div>
      
      {project.data.gallery && project.data.gallery.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold mb-6">Project Gallery</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {project.data.gallery.map((image: string, index: number) => (
              <div class="rounded-lg overflow-hidden shadow-md">
                <img 
                  src={image} 
                  alt={`${project.data.title} gallery ${index + 1}`}
                  class="w-full h-64 object-cover hover:scale-105 transition-transform duration-300"
                />
              </div>
            ))}
          </div>
        </div>
      )}
      
      {(project.data.liveUrl || project.data.githubUrl) && (
        <div class="flex gap-4 pt-8 border-t border-gray-200 dark:border-gray-700">
          {project.data.liveUrl && (
            <a 
              href={project.data.liveUrl} 
              target="_blank" 
              rel="noopener noreferrer"
              class="btn-primary"
            >
              Live Demo
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          )}
          {project.data.githubUrl && (
            <a 
              href={project.data.githubUrl} 
              target="_blank" 
              rel="noopener noreferrer"
              class="btn-secondary"
            >
              View Code
              <svg class="w-4 h-4 ml-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
              </svg>
            </a>
          )}
        </div>
      )}
    </article>
  </div>
</BaseLayout>