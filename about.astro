---
import BaseLayout from '@layouts/BaseLayout.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { getEntry } from 'astro:content';

const aboutEntry = await getEntry('about', 'index');
const { profileImage, socialLinks } = aboutEntry?.data || { profileImage: '/images/placeholder.svg', socialLinks: [] };
const { Content } = await aboutEntry?.render() || { Content: () => <p>About content goes here</p> };
---

<BaseLayout title="About Me">
  <div class="container-custom py-16">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <div class="relative inline-block">
          <img 
            src={profileImage} 
            alt="Profile" 
            class="w-40 h-40 rounded-full object-cover border-4 border-purple-600 shadow-xl"
          />
        </div>
      </div>
      
      <div class="prose prose-lg dark:prose-invert max-w-none mx-auto">
        <Content />
      </div>
      
      {socialLinks && socialLinks.length > 0 && (
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <h3 class="text-2xl font-bold text-center mb-6">Connect with me</h3>
          <SocialLinks links={socialLinks} />
        </div>
      )}
    </div>
  </div>
</BaseLayout>