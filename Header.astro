---
import { getEntry } from 'astro:content';
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.astro';

const settings = await getEntry('settings', 'settings');
const siteTitle = settings?.data?.siteTitle || 'Portfolio';
const logo = settings?.data?.logo || '/favicon.svg';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <a href="/" class="flex items-center space-x-2 text-xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">
        <img src={logo} alt={siteTitle} class="h-8 w-auto" />
        <span>{siteTitle}</span>
      </a>
      
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Home</a>
        <a href="/projects" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Projects</a>
        <a href="/about" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">About</a>
        <a href="/contact" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Contact</a>
        <ThemeToggle />
      </nav>
      
      <div class="flex items-center md:hidden space-x-4">
        <ThemeToggle />
        <MobileNav />
      </div>
    </div>
  </div>
</header>